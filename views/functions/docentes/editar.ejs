<%- include('../../components/header') %>

<h1>Editar Docente</h1>

<form action="/editar_docente/<%= docente.matricula_docente %>" method="POST" style="max-width: 500px; margin: 20px 0;">
    
    <div style="margin-bottom: 15px;">
        <label for="nombre" style ="display:block; margin-bottom: 5px;
         font-weight: bold;">Nombre:</label>
         <input type="text" id="nombre" name="nombre" value="<%= docente.nombre %>" required style="width: 100%; padding: 8px;
            border: 1px solid #ccc; border-radius: 4px;">
    </div>
   
    <div style="margin-bottom: 15px;">
        <label for="carrera" style="display: block; margin-bottom: 5px;
        font-weight: bold;">Carrera:</label>
        <select id="carrera" name="carrera" required style="width: 100%; padding: 8px;
        border: 1px solid #ccc; border-radius: 4px;">
            <% carreras.forEach(carrera => { %>
                    <option value="<%= carrera.id_carrera %>" <%= carrera.id_carrera === docente.id_carrera ? 'selected' : '' %>><%= carrera.nombre_carrera %></option>
                <% }) %>
            </select>

    <button type="submit" style="background-color: #007bff; color: white; padding: 10px 20px; border: none; border-radius: 4px; cursor: pointer;">Guardar Cambios</button>
    <a href="/docentes" style="background-color: #6c757d; color: white; padding: 10px 20px; text-decoration: none; 
    border-radius: 4px; margin-left: 10px;">Cancelar</a>
</form>

<%- include('../../components/footer') %>