<%- include('../../components/header') %>

<h1>Asignar Curso a <%= docente.nombre %></h1>
<% if(cursos.length > 0) { %>


<form action="/horario_docente/<%= docente.matricula_docente %>" method="POST" style="max-width: 500px; margin: 20px 0;">
    
    <div style="margin-bottom: 15px;">
        <label for="nombre" style ="display:block; margin-bottom: 5px;
         font-weight: bold;">Nombre:</label>
        <select id="nombre" name="nombre" required 
    style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;">
    
    <option value="">Selecciona un curso</option>

    <% cursos.forEach(function(curso){ %>
        <option value="<%= curso.id_curso %>">
            <%= curso.nombre_materia %>
        </option>
    <% }); %>
</select>
    </div>
        <div style="margin-bottom: 15px; display: flex; align-items: center; justify-content: space-between;">
            <div>
                <label for="horario_inicio" style="display:block; margin-bottom: 5px; font-weight: bold;">Horario Inicio:</label>
                <input type="time" id="horario_inicio" name="horario_inicio" required 
                style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;">
            </div>
            <div style="margin-top: 15px;">
                <label for="horario_fin" style="display:block; margin-bottom: 5px; font-weight: bold;">Horario Fin:</label>
                <input type="time" id="horario_fin" name="horario_fin" required 
                style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;">
            </div>
        </div>


    <button type="submit" style="background-color: #007bff; color: white; padding: 10px 20px; border: none; border-radius: 4px; cursor: pointer;">Guardar Cambios</button>
    <a href="/docentes" style="background-color: #6c757d; color: white; padding: 10px 20px; text-decoration: none; 
    border-radius: 4px; margin-left: 10px;">Cancelar</a>
</form>
<% } else { %>
    <p style="margin-top: 20px; color: gray;">No hay cursos registrados. Por favor, agrega un curso antes de asignar un horario.</p>
<% } %>


<%- include('../../components/footer') %>